{
  "expo": {
    "name": "medicare",
    "slug": "medicare",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#190A12"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#190A12"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mosadbasha.medicare",
      "versionCode": 10,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon-48.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "b83a3765-46cb-4cbf-9acc-3b21487cdcb2"
      }
    },
    "owner": "mohamedmosad1412"
  }
}
